<section class="max-w-2xl mx-auto p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Create New Event</h1>
    <p class="text-slate-500 text-sm mt-1">
      Events are saved as drafts and are not visible to members until you publish them.
    </p>
  </div>

  <% if (pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
  <% } %>

  <form method="post" action="/events/create" class="space-y-5">
    <div>
      <label for="title" class="block text-sm font-medium text-slate-700 mb-1">Event Title *</label>
      <input
        type="text"
        id="title"
        name="title"
        required
        minlength="3"
        maxlength="200"
        value="<%= input.title || '' %>"
        placeholder="e.g. CS326 Programming Contest"
        class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500"
      />
    </div>

    <div>
      <label for="description" class="block text-sm font-medium text-slate-700 mb-1">Description *</label>
      <textarea
        id="description"
        name="description"
        required
        minlength="10"
        maxlength="5000"
        rows="4"
        placeholder="Tell people what this event is about..."
        class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500"
      ><%= input.description || '' %></textarea>
    </div>

    <div>
      <label for="location" class="block text-sm font-medium text-slate-700 mb-1">Location *</label>
      <input
        type="text"
        id="location"
        name="location"
        required
        maxlength="300"
        value="<%= input.location || '' %>"
        placeholder="Building name, room number, or full address"
        class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500"
      />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="startDate" class="block text-sm font-medium text-slate-700 mb-1">Start Date & Time *</label>
        <input
          type="datetime-local"
          id="startDate"
          name="startDate"
          required
          value="<%= input.startDate || '' %>"
          class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500"
        />
      </div>

      <div>
        <label for="endDate" class="block text-sm font-medium text-slate-700 mb-1">End Date & Time *</label>
        <input
          type="datetime-local"
          id="endDate"
          name="endDate"
          required
          value="<%= input.endDate || '' %>"
          class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500"
        />
      </div>
    </div>

    <div>
      <label for="capacity" class="block text-sm font-medium text-slate-700 mb-1">Maximum Capacity</label>
      <input
        type="number"
        id="capacity"
        name="capacity"
        min="0"
        max="100000"
        value="<%= input.capacity || '' %>"
        placeholder="Leave empty or 0 for unlimited"
        class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500"
      />
      <p class="text-slate-500 text-xs mt-1">If 0, the event will have unlimited capacity.</p>
    </div>

    <div class="pt-4 border-t border-slate-100 flex justify-end gap-3">
      <a
        href="/home"
        class="px-5 py-2.5 rounded-lg border border-slate-300 text-slate-700 font-medium hover:bg-slate-50 no-underline"
      >
        Cancel
      </a>
      <button
        type="submit"
        class="px-5 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 shadow-sm"
      >
        Save as Draft
      </button>
    </div>
  </form>
</section>
