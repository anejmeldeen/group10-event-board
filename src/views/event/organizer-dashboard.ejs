<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Organizer Dashboard</h1>
    <p class="text-slate-500 mt-1">Manage your events across all stages.</p>
  </div>
  <a
    href="/events/create"
    class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl shadow-sm transition-colors no-underline"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
    Create Event
  </a>
</div>

<% if (!published.length && !draft.length && !cancelledOrPast.length) { %>
  <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center shadow-sm">
    <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
    <h3 class="text-lg font-bold text-slate-900">No events found</h3>
    <p class="text-slate-500 mt-1">You haven't created any events yet. Click "Create Event" to get started.</p>
  </div>
<% } else { %>
  <div class="space-y-10">

    <!-- Published Section -->
    <% if (published.length > 0) { %>
  <section>
    <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2 border-b border-slate-200 pb-2">
      <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
      Published / Live
      <span class="text-sm font-normal text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full"><%= published.length %></span>
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% published.forEach(event => { %>
        <%- include("partials/organizer-dashboard-row", { item: event }) %>
      <% }) %>
    </div>
  </section>
<% } %>

    <!-- Draft Section -->
    <% if (draft.length > 0) { %>
  <section>
    <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2 border-b border-slate-200 pb-2">
      <span class="w-3 h-3 rounded-full bg-amber-400"></span>
      Drafts
      <span class="text-sm font-normal text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full"><%= draft.length %></span>
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% draft.forEach(event => { %>
        <%- include("partials/organizer-dashboard-row", { item: event }) %>
      <% }) %>
    </div>
  </section>
<% } %>

    <!-- Past/Cancelled Section -->
    <% if (cancelledOrPast.length > 0) { %>
  <section>
    <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2 border-b border-slate-200 pb-2">
      <span class="w-3 h-3 rounded-full bg-slate-400"></span>
      Past & Cancelled
      <span class="text-sm font-normal text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full"><%= cancelledOrPast.length %></span>
    </h2>
    <div class="space-y-3">
      <% cancelledOrPast.forEach(event => { %>
        <%- include("partials/organizer-dashboard-row", { item: event }) %>
      <% }) %>
    </div>
  </section>
<% } %>

  </div>
<% } %>
