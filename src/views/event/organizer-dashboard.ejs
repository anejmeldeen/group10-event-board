<h1>Organizer Dashboard</h1>

<h2>Draft Events</h2>
<% if (draft.length === 0) { %>
    <p>No draft events.</p>
<% } else { %>
    <ul>
        <% draft.forEach(event => { %>
            <li>
                <strong><%= event.title %></strong>
                (<%= event.category %>)<br/>
                <%= event.startDate %> → <%= event.endDate %><br/>
                Attendees: <%= event.attendeeCount %> / <%= event.capacity %>
            </li>
        <% }) %>
    </ul>
<% } %>

<hr/>

<h2>Published Events</h2>
<% if (published.length === 0) { %>
    <p>No published events.</p>
<% } else { %>
    <ul>
        <% published.forEach(event => { %>
            <li>
                <strong><%= event.title %></strong>
                (<%= event.category %>)<br/>
                <%= event.startDate %> → <%= event.endDate %><br/>
                Attendees: <%= event.attendeeCount %> / <%= event.capacity %>
            </li>
        <% }) %>
    </ul>
<% } %>

<hr/>

<h2>Cancelled / Past Events</h2>
<% if (cancelledOrPast.length === 0) { %>
    <p>No past or cancelled events.</p>
<% } else { %>
    <ul>
        <% cancelledOrPast.forEach(event => { %>
            <li>
                <strong><%= event.title %></strong>
                (<%= event.category %>)<br/>
                <%= event.startDate %> → <%= event.endDate %><br/>
                Attendees: <%= event.attendeeCount %> / <%= event.capacity %>
            </li>
        <% }) %>
    </ul>
<% } %>
