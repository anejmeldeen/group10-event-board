<div class="space-y-4">
  <div>
    <span class="block text-xs text-slate-500 font-medium mb-1">Attendance</span>
    <div class="flex items-center gap-2">
      <span class="text-slate-900 font-medium text-lg"><%= rsvpView.goingCount %></span>
      <% if (capacity > 0) { %>
        <span class="text-slate-400">/ <%= capacity %> attending</span>
      <% } else { %>
        <span class="text-slate-400">attending (Unlimited)</span>
      <% } %>
    </div>
    <% if (capacity > 0) { %>
      <div class="w-full bg-slate-200 rounded-full h-1.5 mt-2">
        <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= Math.min(100, (rsvpView.goingCount / capacity) * 100) %>%"></div>
      </div>
    <% } %>
  </div>

  <% if (rsvpView.canRsvp) { %>
    <form hx-post="/events/<%= eventId %>/rsvp" hx-target="#rsvp-section" hx-swap="innerHTML">
      <% if (rsvpView.currentStatus === 'none') { %>
        <% const isFull = rsvpView.capacity > 0 && rsvpView.goingCount >= rsvpView.capacity; %>
        <button type="submit" class="w-full py-3 px-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow-md transition-colors text-lg cursor-pointer"><%= isFull ? 'Join Waitlist' : 'RSVP' %></button>
      <% } else if (rsvpView.currentStatus === 'going') { %>
        <button type="submit" class="w-full py-3 px-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg shadow-md transition-colors text-lg cursor-pointer">Cancel RSVP</button>
      <% } else if (rsvpView.currentStatus === 'waitlisted') { %>
        <button type="submit" class="w-full py-3 px-4 bg-amber-600 hover:bg-amber-700 text-white font-bold rounded-lg shadow-md transition-colors text-lg cursor-pointer">Leave Waitlist</button>
      <% } else if (rsvpView.currentStatus === 'cancelled') { %>
        <button type="submit" class="w-full py-3 px-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow-md transition-colors text-lg cursor-pointer">RSVP Again</button>
      <% } %>
    </form>
  <% } else { %>
    <button disabled class="w-full py-3 px-4 bg-slate-300 text-slate-500 font-bold rounded-lg cursor-not-allowed text-lg">Unavailable</button>
  <% } %>
</div>