<section class="max-w-4xl mx-auto p-6">
  <div class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-8 py-10 text-white">
      <% if (event.status === 'draft') { %>
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-wider text-amber-900 bg-amber-400 rounded-full uppercase">Draft</span>
      <% } else if (event.status === 'cancelled') { %>
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-wider text-rose-900 bg-rose-400 rounded-full uppercase">Cancelled</span>
      <% } else { %>
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-wider text-emerald-900 bg-emerald-400 rounded-full uppercase">Published</span>
      <% } %>

      <h1 class="text-4xl font-extrabold mb-2 tracking-tight"><%= event.title %></h1>

      <div class="flex items-center gap-4 text-blue-100 mt-4 text-sm font-medium">
        <div class="flex items-center gap-1.5">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <span><%= new Date(event.startDate).toLocaleString() %> - <%= new Date(event.endDate).toLocaleString() %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          <span><%= event.location %></span>
        </div>
      </div>
    </div>

    <div class="p-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="md:col-span-2 space-y-8">
          <div>
            <h2 class="text-xl font-bold text-slate-900 mb-3">About this Event</h2>
            <p class="text-slate-600 whitespace-pre-wrap leading-relaxed"><%= event.description %></p>
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-slate-50 p-5 rounded-xl border border-slate-100">
            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Event Details</h3>

            <div class="space-y-4">
              <div>
                <span class="block text-xs text-slate-500 font-medium mb-1">Organization / Organizer</span>
                <span class="text-slate-900 font-semibold"><%= event.organizerName %></span>
              </div>

              <div>
                <span class="block text-xs text-slate-500 font-medium mb-1">Category</span>
                <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-indigo-50 text-indigo-700 border border-indigo-100 text-sm font-medium"><%= event.category %></span>
              </div>
            </div>
          </div>

          <div class="pt-2">
            <% if (user.role === 'admin' || user.role === 'staff') { %>
              <%- include("partials/event-status", { event, user }) %>
            <% } else { %>
              <div id="rsvp-section">
                <%- include("partials/rsvp", { rsvpView: rsvpView, eventId: event.id, capacity: event.capacity }) %>
              </div>

              <% if (user.role === 'user') { %>
                <div class="mt-3">
                  <%- include("../partials/saved-toggle-button", {
                    eventId: event.id,
                    saved: typeof isSaved !== 'undefined' ? isSaved : false,
                    returnTo: `/events/${event.id}`,
                    context: "detail",
                    htmx: true,
                  }) %>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>