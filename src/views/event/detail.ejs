<section class="max-w-4xl mx-auto p-6">
  <div class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">
    <!-- Header Section -->
    <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-8 py-10 text-white">
      <% if (event.status === 'draft') { %>
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-wider text-amber-900 bg-amber-400 rounded-full uppercase">
          Draft
        </span>
      <% } else if (event.status === 'cancelled') { %>
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-wider text-rose-900 bg-rose-400 rounded-full uppercase">
          Cancelled
        </span>
      <% } else { %>
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-wider text-emerald-900 bg-emerald-400 rounded-full uppercase">
          Published
        </span>
      <% } %>

      <h1 class="text-4xl font-extrabold mb-2 tracking-tight"><%= event.title %></h1>

      <div class="flex items-center gap-4 text-blue-100 mt-4 text-sm font-medium">
        <div class="flex items-center gap-1.5">
          <!-- Calendar Icon -->
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <span>
            <%= new Date(event.startDate).toLocaleString() %> -
            <%= new Date(event.endDate).toLocaleString() %>
          </span>
        </div>
        <div class="flex items-center gap-1.5">
          <!-- Location Icon -->
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          <span><%= event.location %></span>
        </div>
      </div>
    </div>

    <!-- Body Section -->
    <div class="p-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Left Column: Details -->
        <div class="md:col-span-2 space-y-8">
          <div>
            <h2 class="text-xl font-bold text-slate-900 mb-3">About this Event</h2>
            <p class="text-slate-600 whitespace-pre-wrap leading-relaxed"><%= event.description %></p>
          </div>
        </div>

        <!-- Right Column: Sidebar Info -->
        <div class="space-y-6">
          <div class="bg-slate-50 p-5 rounded-xl border border-slate-100">
            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Event Details</h3>

            <div class="space-y-4">
              <div>
                <span class="block text-xs text-slate-500 font-medium mb-1">Organization / Organizer</span>
                <span class="text-slate-900 font-semibold"><%= event.organizerName %></span>
              </div>

              <div>
                <span class="block text-xs text-slate-500 font-medium mb-1">Category</span>
                <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-indigo-50 text-indigo-700 border border-indigo-100 text-sm font-medium">
                  <%= event.category %>
                </span>
              </div>

              <div>
                <span class="block text-xs text-slate-500 font-medium mb-1">Attendance</span>
                <div class="flex items-center gap-2">
                  <span class="text-slate-900 font-medium text-lg"><%= event.attendeeCount %></span>
                  <% if (event.capacity > 0) { %>
                    <span class="text-slate-400">/ <%= event.capacity %> attending</span>
                  <% } else { %>
                    <span class="text-slate-400">attending (Unlimited)</span>
                  <% } %>
                </div>

                <% if (event.capacity > 0) { %>
                  <!-- Progress Bar -->
                  <div class="w-full bg-slate-200 rounded-full h-1.5 mt-2">
                    <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= Math.min(100, (event.attendeeCount / event.capacity) * 100) %>%"></div>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Action Controls based on Role -->
          <div class="pt-2">
            <% if (user.role === 'admin' || user.role === 'staff') { %>
              <div class="flex flex-col gap-3">
                <% if (event.status === 'draft') { %>
                  <form method="POST" action="/events/<%= event.id %>/publish" class="w-full">
                    <button type="submit" class="w-full py-3 px-4 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-lg shadow-md transition-colors text-lg cursor-pointer">
                      Publish Event
                    </button>
                  </form>
                <% } %>
                <% if ((user.userId === event.organizerId || user.role === 'admin') && event.status !== 'cancelled') { %>
                  <a href="/events/<%= event.id %>/edit" class="block w-full py-2.5 px-4 bg-slate-100 hover:bg-slate-200 text-slate-800 font-semibold rounded-lg border border-slate-300 transition-colors text-center no-underline">
                    Edit Event
                  </a>
                <% } %>
                <button class="w-full py-2.5 px-4 bg-white hover:bg-rose-50 text-rose-600 font-semibold rounded-lg border border-rose-200 transition-colors">
                  Cancel Event
                </button>
              </div>
            <% } else { %>
              <% if (event.status === 'published') { %>
                <button class="w-full py-3 px-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow-md transition-colors text-lg">
                  RSVP Now
                </button>
              <% } else { %>
                <button disabled class="w-full py-3 px-4 bg-slate-300 text-slate-500 font-bold rounded-lg cursor-not-allowed text-lg">
                  Unavailable
                </button>
              <% } %>
            <% } %>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>