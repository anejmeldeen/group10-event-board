<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<!-- Dashboard Header -->
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Event Dashboard</h1>
    <p class="text-slate-500 mt-1">Discover what's happening and plan your schedule.</p>
  </div>
  <% if (user?.role === 'admin' || user?.role === 'staff') { %>
    <a
      href="/events/create"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl shadow-sm transition-colors no-underline"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      Create Event
    </a>
  <% } %>
</div>

<!-- Scrollable Events Feed -->
<div class="space-y-8">
  <% if (!events || events.length === 0) { %>
    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center shadow-sm">
      <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
      <h3 class="text-lg font-bold text-slate-900">No events found</h3>
      <p class="text-slate-500 mt-1">There are currently no events to display.</p>
    </div>
  <% } else { %>
    <% events.forEach(event => { %>
      <article class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden transition-all hover:shadow-xl group">
        <div class="flex flex-col md:flex-row">
          
          <!-- Event Content -->
          <div class="flex-grow p-6 md:p-8">
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <% if (event.status === 'draft') { %>
                  <span class="inline-block px-2.5 py-1 mb-3 text-xs font-bold tracking-wider text-amber-900 bg-amber-200 rounded-md uppercase">Draft</span>
                <% } else if (event.status === 'cancelled') { %>
                  <span class="inline-block px-2.5 py-1 mb-3 text-xs font-bold tracking-wider text-rose-900 bg-rose-200 rounded-md uppercase">Cancelled</span>
                <% } %>
                <h2 class="text-2xl font-bold text-slate-900 tracking-tight leading-tight group-hover:text-blue-700 transition-colors"><%= event.title %></h2>
                <div class="flex items-center text-slate-500 mt-2 text-sm font-medium gap-4">
                  <div class="flex items-center gap-1.5 text-blue-600 bg-blue-50 px-2 py-0.5 rounded-md">
                    <%= event.category %>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <%= event.location %>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <time><%= new Date(event.startDate).toLocaleString() %></time>
                  </div>
                </div>
              </div>
            </div>

            <p class="text-slate-600 line-clamp-3 leading-relaxed mb-6"><%= event.description %></p>
            
            <div class="flex items-center justify-between mt-auto">
              <!-- Attendance Stats -->
              <div class="flex items-center gap-3">
                <div class="flex -space-x-2">
                  <div class="w-8 h-8 rounded-full bg-blue-100 border-2 border-white flex items-center justify-center text-xs font-bold text-blue-700">
                    <%= event.attendeeCount %>
                  </div>
                </div>
                <span class="text-sm font-medium text-slate-500">
                  attending
                  <% if (event.capacity > 0) { %> / <%= event.capacity %> max <% } %>
                </span>
              </div>
              <span class="text-sm text-slate-400 font-medium pb-2 border-b border-transparent">
                By <%= event.organizerName %>
              </span>
            </div>
          </div>

          <!-- Event Sidebar Actions -->
          <div class="bg-slate-50 border-l border-slate-100 p-6 md:p-8 flex flex-col justify-center min-w-[240px]">
            <% if (user?.role === 'admin' || user?.role === 'staff') { %>
              <div class="space-y-3 w-full">
                <a href="/events/<%= event.id %>" class="w-full inline-block text-center py-2.5 px-4 bg-slate-900 hover:bg-slate-800 text-white font-medium rounded-lg shadow-sm transition-colors block">
                  View Full Details
                </a>
                <% if (event.status === 'draft') { %>
                  <form method="POST" action="/events/<%= event.id %>/publish">
                    <button type="submit" class="w-full py-2.5 px-4 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-lg shadow-sm transition-colors cursor-pointer">
                      Publish Event
                    </button>
                  </form>
                <% } else { %>
                  
                <% } %>
              </div>
            <% } else { %>
              <div class="space-y-3 w-full">
                <a href="/events/<%= event.id %>" class="w-full inline-block text-center py-3 px-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow-md transition-colors text-lg no-underline">
                  View Event
                </a>
              </div>
            <% } %>
          </div>

        </div>
      </article>
    <% }) %>
  <% } %>
</div>

