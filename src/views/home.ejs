<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Event Dashboard</h1>
    <p class="text-slate-500 mt-1">Discover what's happening and plan your schedule.</p>
  </div>

  <div class="flex gap-3">
    <% if (user?.role === 'user') { %>
      <a
        href="/saved"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900 hover:bg-slate-800 text-white font-semibold rounded-xl shadow-sm transition-colors no-underline"
      >
        Saved Events
      </a>
    <% } %>

    <% if (user?.role === 'admin' || user?.role === 'staff') { %>
      <a
        href="/events/create"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl shadow-sm transition-colors no-underline"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Create Event
      </a>
    <% } %>
  </div>
</div>

<form
  method="GET"
  action="/home"
  class="mb-8 space-y-3"
  hx-get="/home"
  hx-trigger="keyup changed delay:300ms from:input[name='q'], change from:select, submit"
  hx-target="#event-list"
  hx-swap="innerHTML"
>
  <div class="flex gap-3">
    <input
      type="text"
      name="q"
      value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
      placeholder="Search by title, description, or location"
      class="flex-1 px-4 py-3 rounded-xl border border-slate-300 bg-white shadow-sm"
    />
    <button
      type="submit"
      class="px-5 py-3 bg-slate-900 hover:bg-slate-800 text-white font-semibold rounded-xl shadow-sm"
    >
      Search
    </button>
  </div>

  <div class="flex gap-3">
    <select
      name="category"
      class="px-4 py-3 rounded-xl border border-slate-300 bg-white shadow-sm"
    >
      <option value="">All categories</option>
      <option value="social" <%= selectedCategory === "social" ? "selected" : "" %>>Social</option>
      <option value="educational" <%= selectedCategory === "educational" ? "selected" : "" %>>Educational</option>
      <option value="volunteer" <%= selectedCategory === "volunteer" ? "selected" : "" %>>Volunteer</option>
      <option value="sports" <%= selectedCategory === "sports" ? "selected" : "" %>>Sports</option>
      <option value="arts" <%= selectedCategory === "arts" ? "selected" : "" %>>Arts</option>
    </select>

    <select
      name="timeframe"
      class="px-4 py-3 rounded-xl border border-slate-300 bg-white shadow-sm"
    >
      <option value="">All upcoming</option>
      <option value="this-week" <%= selectedTimeframe === "this-week" ? "selected" : "" %>>This week</option>
      <option value="this-weekend" <%= selectedTimeframe === "this-weekend" ? "selected" : "" %>>This weekend</option>
    </select>
  </div>
</form>

<div id="event-list">
  <%- include("event/partials/event-list", { events, user, savedEventIds: typeof savedEventIds !== 'undefined' ? savedEventIds : new Set() }) %>
</div>