<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Event Dashboard</h1>
    <p class="text-slate-500 mt-1">Discover what's happening and plan your schedule.</p>
  </div>
  <% if (user?.role === 'admin' || user?.role === 'staff') { %>
    <a
      href="/events/create"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl shadow-sm transition-colors no-underline"
    >
      Create Event
    </a>
  <% } %>
</div>

<form method="GET" action="/home" class="mb-8">
  <div class="flex gap-3">
    <input
      type="text"
      name="q"
      value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
      placeholder="Search by title, description, or location"
      class="flex-1 px-4 py-3 rounded-xl border border-slate-300 bg-white shadow-sm"
    />
    <button
      type="submit"
      class="px-5 py-3 bg-slate-900 hover:bg-slate-800 text-white font-semibold rounded-xl shadow-sm"
    >
      Search
    </button>
  </div>
</form>

<div class="space-y-8">
  <% if (!events || events.length === 0) { %>
    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center shadow-sm">
      <h3 class="text-lg font-bold text-slate-900">No events found</h3>
      <p class="text-slate-500 mt-1">There are currently no events to display.</p>
    </div>
  <% } else { %>
    <% events.forEach(event => { %>
      <article class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden transition-all hover:shadow-xl group">
        <div class="flex flex-col md:flex-row">
          <div class="flex-grow p-6 md:p-8">
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <% if (event.status === 'draft') { %>
                  <span class="inline-block px-2.5 py-1 mb-3 text-xs font-bold tracking-wider text-amber-900 bg-amber-200 rounded-md uppercase">Draft</span>
                <% } else if (event.status === 'cancelled') { %>
                  <span class="inline-block px-2.5 py-1 mb-3 text-xs font-bold tracking-wider text-rose-900 bg-rose-200 rounded-md uppercase">Cancelled</span>
                <% } %>
                <h2 class="text-2xl font-bold text-slate-900 tracking-tight leading-tight group-hover:text-blue-700 transition-colors"><%= event.title %></h2>
                <div class="flex items-center text-slate-500 mt-2 text-sm font-medium gap-4">
                  <div class="flex items-center gap-1.5 text-blue-600 bg-blue-50 px-2 py-0.5 rounded-md">
                    <%= event.category %>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <%= event.location %>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <time><%= new Date(event.startDate ?? event.startAt).toLocaleString() %></time>
                  </div>
                </div>
              </div>
            </div>

            <p class="text-slate-600 line-clamp-3 leading-relaxed mb-6"><%= event.description %></p>

            <div class="flex items-center justify-between mt-auto">
              <div class="flex items-center gap-3">
                <div class="flex -space-x-2">
                  <div class="w-8 h-8 rounded-full bg-blue-100 border-2 border-white flex items-center justify-center text-xs font-bold text-blue-700">
                    <%= event.attendeeCount ?? 0 %>
                  </div>
                </div>
                <span class="text-sm font-medium text-slate-500">
                  attending
                  <% if (event.capacity > 0) { %> / <%= event.capacity %> max <% } %>
                </span>
              </div>
              <span class="text-sm text-slate-400 font-medium pb-2 border-b border-transparent">
                By <%= event.organizerName ?? 'Unknown Organizer' %>
              </span>
            </div>
          </div>

          <div class="bg-slate-50 border-l border-slate-100 p-6 md:p-8 flex flex-col justify-center min-w-[240px]">
            <div class="space-y-3 w-full">
              <a href="/events/<%= event.id %>" class="w-full inline-block text-center py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg shadow-sm transition-colors block no-underline">
                View Event
              </a>

              <% if (user?.role === 'user') { %>
                <form method="POST" action="/saved/<%= event.id %>/toggle">
                  <button
                    type="submit"
                    class="w-full py-2.5 px-4 bg-slate-900 hover:bg-slate-800 text-white font-medium rounded-lg shadow-sm transition-colors cursor-pointer"
                  >
                    Save / Unsave
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      </article>
    <% }) %>
  <% } %>
</div>