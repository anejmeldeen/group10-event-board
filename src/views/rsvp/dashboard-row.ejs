<article id="rsvp-row-<%= item.eventId %>" class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm hover:shadow-md transition-shadow">
    <div class="flex items-start justify-between gap-4">
        <div class="flex-grow">
            <div class="flex items-center gap-2 mb-1">
                <span class="inline-block px-2 py-0.5 text-xs font-bold rounded-md <%= item.rsvpStatus === 'going' ? 'bg-emerald-100 text-emerald-800' : item.rsvpStatus === 'waitlisted' ? 'bg-amber-100 text-amber-800' : 'bg-rose-100 text-rose-800' %>">
                    <%= item.rsvpStatus.charAt(0).toUpperCase() + item.rsvpStatus.slice(1) %>
                </span>
                <span class="text-xs text-blue-600 bg-blue-50 px-2 py-0.5 rounded-md font-medium"><%= item.category %></span>
            </div>
        <h3 class="text-lg font-bold text-slate-900"><%= item.title %></h3>
        <div class="flex items-center gap-4 mt-2 text-sm text-slate-500">
            <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <%= item.location %>
            </span>
            <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <time><%= new Date(item.startDate).toLocaleString() %></time>
            </span>
            <span class="text-slate-400">by <%= item.organizerName %></span>
        </div>
    </div>
    <% if (item.rsvpStatus !== 'cancelled') { %>
        <button
            hx-post="/events/<%= item.eventId %>/rsvp/cancel"
            hx-target="#rsvp-row-<%= item.eventId %>"
            hx-swap="outerHTML"
            class="px-3 py-1.5 text-sm font-medium text-rose-600 border border-rose-200 rounded-lg hover:bg-rose-50 transition-colors"
            >
                Cancel RSVP
        </button>
        <% } %>
    </div>
</article>