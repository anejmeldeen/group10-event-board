<% if (!upcoming.length && !history.length) { %>
  <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center shadow-sm">
    <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
    <h1 class="text-2xl font-bold text-slate-900">My RSVPs</h1>
    <p class="text-slate-500 mt-2">You haven&apos;t RSVPed to any events yet. Browse events on the <a href="/home" class="text-blue-600 hover:underline font-medium">dashboard</a> and start signing up!</p>
  </div>
<% } else { %>
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">My RSVPs</h1>
    <p class="text-slate-500 mt-1">Events you've signed up for.</p>
  </div>

  <% if (upcoming.length > 0) { %>
    <section class="mb-10">
      <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
        Upcoming
        <span class="text-sm font-normal text-slate-400">(<%= upcoming.length %>)</span>
      </h2>
      <div class="space-y-4">
        <% upcoming.forEach(item => { %>
          <%- include("dashboard-row", { item }) %>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (history.length > 0) { %>
    <section>
      <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-slate-400"></span>
        History
        <span class="text-sm font-normal text-slate-400">(<%= history.length %>)</span>
      </h2>
      <div class="space-y-4">
  <% history.forEach(item => { %>
          <a href="/events/<%= item.eventId %>" class="block no-underline">
            <article class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm opacity-70">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-block px-2 py-0.5 text-xs font-bold rounded-md bg-slate-100 text-slate-600">
                  <%= item.rsvpStatus.charAt(0).toUpperCase() + item.rsvpStatus.slice(1) %>
                </span>
                <% if (item.eventStatus === 'cancelled') { %>
                  <span class="inline-block px-2 py-0.5 text-xs font-bold rounded-md bg-rose-100 text-rose-800">Event Cancelled</span>
                <% } %>
              </div>
              <h3 class="text-lg font-bold text-slate-900"><%= item.title %></h3>
              <p class="text-sm text-slate-500 mt-1"><%= item.location %> &middot; by <%= item.organizerName %></p>
            </article>
          </a>
        <% }) %>
        </div>
    </section>
  <% } %>
<% } %>